  235  import os
  236  import stripe
  237  from flask import Flask, redirect, request, send_from_directory
  239  app = Flask(__name__, static_folder='public')
  240  YOUR_DOMAIN = os.environ.get('APP_DOMAIN', 'http://localhost:4242')
  241  @app.route('/')
  242  def index():
  243      return redirect('/checkout.html')
  244  @app.route('/checkout.html')
  245  def checkout():
  246      return send_from_directory('public', 'checkout.html')
  247  @app.route('/success.html')
  248  def success():
  249      return send_from_directory('public', 'success.html')
  250  @app.route('/cancel.html')
  251  def cancel():
  252      return send_from_directory('public', 'cancel.html')
  253  @app.route('/create-checkout-session', methods=['POST'])
  254  def create_checkout_session():
  255      try:
  256          checkout_session = stripe.checkout.Session.create(
  257              line_items=[
  258                  {
  259                      'price_data': {
  260                          'currency': 'eur',
  261                          'product_data': {
  262                              'name': 'T-shirt',
  263                          },
  264                          'unit_amount': 2000,
  265                      },
  266                      'quantity': 1,
  267                  },
  268              ],
  269              mode='payment',
  270              success_url=YOUR_DOMAIN + '/success.html',
  271              cancel_url=YOUR_DOMAIN + '/cancel.html',
  272          )
  273      except Exception as e:
  274          return str(e), 400
  275      return redirect(checkout_session.url, code=303)
  276  @app.route('/health')
  277  def health():
  278      env = os.environ.get('APP_ENV', 'unknown')
  279      return f'OK - env: {env}'
  280  if __name__ == '__main__':
  281      app.run(host='0.0.0.0', port=4242)
  282  EOF
